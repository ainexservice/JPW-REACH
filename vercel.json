{
  "version": 2,

  "functions": {
    "api/create-order.js": {
      "runtime": "@vercel/node"
    },
    "api/verify-payment.js": {
      "runtime": "@vercel/node"
    }
  },

  "routes": [
    {
      "src": "/api/create-order",
      "dest": "/api/create-order.js"
    },
    {
      "src": "/api/verify-payment",
      "dest": "/api/verify-payment.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}